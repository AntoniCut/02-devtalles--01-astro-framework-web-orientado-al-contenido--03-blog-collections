---


/*
    *  -------------------------------------------------------------  *
    *  -----  [slug].astro  --  /src/pages/posts/[slug].astro  -----  *
    *  -------------------------------------------------------------  *
*/


import type { GetStaticPaths } from "astro";
import { getCollection, getEntry, render } from "astro:content";
import { Image } from "astro:assets";
import BlogLayout from "@layouts/BlogLayout.astro";

import Author from "@components/Author.astro";
import BlogDate from "@components/BlogDate.astro";


/** -----  Get the static paths  ----- */
export const getStaticPaths = (async () => {

    /** -----  Get the blog posts  ----- */
    const blogPosts = await getCollection('blog');

    /** -----  Return the static paths  ----- */
    return blogPosts.map(post => ({
        params: { slug: post.id },
        props: { post },
    }));

}) satisfies GetStaticPaths;


const { post } = Astro.props;


console.clear();
console.log('post => ', post);

/** - `ID del post` */
const id = post.id;

/** - `Frontmatter del post` */
const frontmatter = post.data;

/** - `Title, Author, image del frontmatter` */
const { title, author, image } = frontmatter;

/** - `Resolver la referencia del autor` */
const authorEntry = await getEntry(author);


/** - `ID del autor` */
const authorId = frontmatter.author.id;

/** - `Nombre del autor` */
const authorName = authorEntry?.data.name ?? 'Desconocido';

/** - `Avatar del autor` */
const authorAvatar = authorEntry!.data.avatar;


/** -----  Get the content and headings of the post ----- */
const { Content, headings } = await render(post);


---


<BlogLayout frontmatter={{ title, author: authorName, image }}>
    

    <h2 class="text-xs text-gray-500 mb-0 border-b-2 border-blue-800 pb-1 font-bold">
        {title}  
    </h2>


    <Author name={authorName} avatar={authorAvatar} id={authorId} />

    <BlogDate date={new Date(frontmatter.date)} />
       
    

    <!--  -----  Imagen  -----  -->
    <Image 

        class="object-cover w-full h-[300px] rounded-md my-10 place-self-center-safe" 
        src={image}
        alt={title}
        width={600}
        height={600}
        quality="low"
        loading="lazy"
        transition:name={`${id}-image`}
    />
    

    <!--  -----  Tabla de contenidos  -----  -->
    <h3 class="border-b-2 border-blue-800 w-3xs"> 
        Tabla de contenidos 
    </h3>

    <!--  -----  Iteración de la tabla de contenidos -----  -->       
    <ol class="mb-5 list-decimal list-inside">
        {
            headings.map((heading, index) => (
                <li>
                    <a href={`#${heading.slug}`}> {index + 1} - {heading.text}</a>
                </li>
            ))  
        }
    </ol>

    <!--*  -----  Contenido  -----   -->
    <Content />

</BlogLayout>

