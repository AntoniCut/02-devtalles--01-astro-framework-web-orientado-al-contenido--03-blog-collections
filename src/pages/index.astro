---

/*

    *  -----------------------------------------------------  *
    *  -----  index.astro  --  /src/pages/index.astro  -----  *
    *  -----------------------------------------------------  *
*/


import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site-config.ts';
import BlogPost from '@components/BlogPost.astro';
import type { MarkdownPost } from '@interfaces/markdown.ts';


/** -----  Import all blog posts  ----- */
const matches = import.meta.glob<MarkdownPost>(
    './posts/*.{md,mdx}',
    { eager: true }
);

/** -----  Get all posts  ----- */
const posts = Object.values(matches);

/** -----  Get all frontmatter  ----- */
const frontmatter = posts.map((post) => post.frontmatter);

//  -----  Debug  -----
console.log(' ~ matches  => ', matches);
console.log(' ~ posts  => ', posts);


console.log(' ~ frontmatter  => ', frontmatter);

---

<Layout title="Blog">
    <section class="bg-dark:bg-gray-900">
        <div class="container px-6 py-10 mx-auto">
            <h1 class="text-3xl font-semibold text-amber-100 capitalize lg:text-4xl dark:text-white">
                {siteConfig.title}
            </h1>

            <!--  -----  Posts Container  ----- -->
            <div class="grid grid-cols-1 gap-8 mt-8 md:mt-16 md:grid-cols-2">
                
                {
                    posts.map((post) => (
                        <BlogPost {...post} />
                    ))
                }
                                
            </div>

        </div>

    </section>
	
</Layout>
