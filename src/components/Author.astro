---

/*
    *  ------------------------------------------------------------  *
    *  -----  Author.astro  --  /src/components/Author.astro  -----  *
    *  ------------------------------------------------------------  *
*/


import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { base } from "@config/base-project";


interface Props {
    name: string;
    avatar: ImageMetadata;
    id: string;
}

const { name, avatar, id } = Astro.props;

---


<!--*  -----  Author Container  ----- -->
<div class="w-56 h-16 flex justify-center items-center gap-4 text-md text-gray-400 mb-5">
        
    <Image
        class="rounded-full w-10 h-10"
        src={avatar}
        alt={name}
        width={40}
        height={40}
        quality="low"
        loading="lazy"
        transition:name={`${id}-author-avatar`}
    />

    <!--*  -----  Nombre del autor  -----  -->
    <div class="flex flex-col">
        
        <!--*  -----  Enlace al autor  -----  -->
        <a href={`${base}/blog/${id}`} class="text-md text-gray-400">
            {name}
        </a>

    </div>

</div>

