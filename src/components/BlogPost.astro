---

/*
    *  ----------------------------------------------------------------  *
    *  -----  BlogPost.astro  --  /src/components/BlogPost.astro  -----  *
    *  ----------------------------------------------------------------  *
*/


import type { BlogFrontmatter } from '@interfaces/blog';
import { Formatter } from '@utils/formatter';


interface Props {
    frontmatter: BlogFrontmatter;
    url: string;
}

const { frontmatter, url } = Astro.props;


console.log('frontmatter props => ', frontmatter);
console.log('url props => ', url);

---


<!--  -----  Blog Item  -----  -->
<div class="lg:flex">
                    
    <img 
        class="object-cover w-full h-56 rounded-lg lg:w-64" 
        src={frontmatter.image}
        alt={frontmatter.title}
    >

    <div class="flex flex-col justify-between py-6 lg:mx-6">
        
        <a 
            href={url} 
            class="text-white text-xl font-semibold hover:underline"
        >
            {frontmatter.description}
        </a>
                    
        <span class="text-sm text-gray-500">
            {
                Formatter.formatDate(frontmatter.date)
            }
        </span>
    
    </div>

</div>


<style>

    a {
       color: white
    }

    a:hover {
       color: #ffd5d5
    }

</style>